<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9FAFB"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/title_advance_report"
            android:textColor="@color/text_primary"
            android:textSize="26sp"
            android:fontFamily="sans-serif-black"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/subtitle_advance_report"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp">

            <!-- Filters Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/border_light"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Labour Selection (Moved to top) -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_labour_selection"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold"
                        android:textSize="13sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSelectLabours"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="6dp"
                        android:text="All Labourers"
                        android:textAllCaps="false"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        app:cornerRadius="8dp"
                        app:icon="@drawable/ic_chevron_down"
                        app:iconGravity="end"
                        app:iconTint="@color/text_secondary"
                        app:strokeColor="@color/border_light" />

                    <!-- Date Range Selection -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_from_date"
                                android:textColor="@color/text_secondary"
                                android:textSize="11sp"
                                android:textAllCaps="true"
                                android:letterSpacing="0.05"
                                android:layout_marginBottom="4dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnFromDate"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                app:cornerRadius="8dp"
                                android:text="01-01-2024"
                                android:textAllCaps="false"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                app:strokeColor="@color/border_light" />
                        </LinearLayout>

                        <View
                            android:layout_width="12dp"
                            android:layout_height="1dp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_to_date"
                                android:textColor="@color/text_secondary"
                                android:textSize="11sp"
                                android:textAllCaps="true"
                                android:letterSpacing="0.05"
                                android:layout_marginBottom="4dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnToDate"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                app:cornerRadius="8dp"
                                android:text="31-01-2024"
                                android:textAllCaps="false"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                app:strokeColor="@color/border_light" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Type and Group Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_labour_type"
                                android:textColor="@color/text_primary"
                                android:textStyle="bold"
                                android:textSize="13sp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnSelectTypes"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:layout_marginTop="6dp"
                                android:text="All Types"
                                android:textAllCaps="false"
                                android:textColor="@color/text_primary"
                                android:textSize="13sp"
                                app:cornerRadius="8dp"
                                app:icon="@drawable/ic_chevron_down"
                                app:iconGravity="end"
                                app:iconTint="@color/text_secondary"
                                app:strokeColor="@color/border_light" />
                        </LinearLayout>

                        <View
                            android:layout_width="12dp"
                            android:layout_height="1dp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/btn_groups"
                                android:textColor="@color/text_primary"
                                android:textStyle="bold"
                                android:textSize="13sp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnSelectGroups"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:layout_marginTop="6dp"
                                android:text="All Groups"
                                android:textAllCaps="false"
                                android:textColor="@color/text_primary"
                                android:textSize="13sp"
                                app:cornerRadius="8dp"
                                app:icon="@drawable/ic_chevron_down"
                                app:iconGravity="end"
                                app:iconTint="@color/text_secondary"
                                app:strokeColor="@color/border_light" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Active Filter Preview -->
                    <TextView
                        android:id="@+id/tvActiveFiltersPreview"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Showing: All Records"
                        android:textColor="@color/text_muted"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium"
                        android:visibility="visible" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnApplyFilters"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginTop="20dp"
                        android:text="@string/btn_generate_report"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        app:backgroundTint="@color/brand_primary"
                        app:cornerRadius="12dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Summary Section -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:visibility="gone"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/brand_primary">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TOTAL ADVANCES"
                        android:textColor="#B3FFFFFF"
                        android:textSize="11sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.1"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvSummaryTotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="SAR 0"
                        android:textColor="@color/white"
                        android:textSize="28sp"
                        android:fontFamily="sans-serif-black" />

                    <View
                        android:layout_width="40dp"
                        android:layout_height="2dp"
                        android:layout_marginTop="12dp"
                        android:background="#33FFFFFF" />

                    <TextView
                        android:id="@+id/tvSummaryCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="0 Labourers"
                        android:textColor="@color/white"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvSummaryByType"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="#E6FFFFFF"
                        android:textSize="12sp"
                        android:lineSpacingExtra="2dp" />

                    <TextView
                        android:id="@+id/tvSummaryByGroup"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textColor="#E6FFFFFF"
                        android:textSize="12sp"
                        android:lineSpacingExtra="2dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Report Results -->
            <LinearLayout
                android:id="@+id/containerReport"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="8dp" />

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        android:background="@color/white"
        android:elevation="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnExportReport"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="@string/btn_export_report"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textSize="15sp"
            android:visibility="gone"
            app:cornerRadius="12dp"
            app:strokeColor="@color/brand_primary"
            android:textColor="@color/brand_primary"
            android:insetTop="0dp"
            android:insetBottom="0dp" />
    </LinearLayout>

</LinearLayout>
