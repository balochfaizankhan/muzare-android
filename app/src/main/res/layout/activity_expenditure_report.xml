<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/expReportRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/title_expenditure"
        android:textColor="@color/text_primary"
        android:textSize="28sp"
        android:fontFamily="sans-serif-black"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="0dp"
        android:layout_marginBottom="24dp"
        android:text="Expenditure Reporting"
        android:textColor="@color/text_secondary"
        android:textSize="15sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonFilterCategories"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            app:backgroundTint="@color/brand_primary"
            app:cornerRadius="12dp"
            android:text="@string/btn_select_cats"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="13sp"
            android:paddingHorizontal="4dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:gravity="center" />

        <View
            android:layout_width="12dp"
            android:layout_height="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonFilterAccounts"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            app:backgroundTint="@color/brand_primary"
            app:cornerRadius="12dp"
            android:text="@string/btn_select_accounts"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="13sp"
            android:paddingHorizontal="4dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:gravity="center" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonSelectFromDate"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            app:backgroundTint="@color/brand_primary"
            app:cornerRadius="12dp"
            android:text="@string/btn_select_start"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="13sp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:gravity="center" />

        <View
            android:layout_width="12dp"
            android:layout_height="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonSelectToDate"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            app:backgroundTint="@color/brand_primary"
            app:cornerRadius="12dp"
            android:text="@string/btn_select_end"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="13sp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:gravity="center" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonViewReport"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="16dp"
        app:backgroundTint="@color/brand_primary"
        app:cornerRadius="12dp"
        android:text="@string/btn_generate_report"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:textSize="16sp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:gravity="center" />

    <TextView
        android:id="@+id/textViewReportSummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_card"
        android:padding="16dp"
        android:elevation="1dp"
        android:text="@string/summary_placeholder"
        android:textColor="@color/text_primary"
        android:textSize="15sp"
        android:fontFamily="sans-serif-medium" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="12dp">

        <LinearLayout
            android:id="@+id/reportContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonExportReport"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="16dp"
        app:backgroundTint="@color/brand_primary"
        app:cornerRadius="12dp"
        android:text="@string/btn_export_report"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:textSize="16sp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:gravity="center" />

</LinearLayout>